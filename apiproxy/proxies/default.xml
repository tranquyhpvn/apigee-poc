<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<ProxyEndpoint name="default">
    <Description>Inbound proxy endpoint</Description>
    <HTTPProxyConnection>
        <BasePath>/sample</BasePath>
    </HTTPProxyConnection>
    <FaultRules/>
    <PreFlow name="PreFlow">
        <Request>
            <Step><Name>KV-LookupVersion</Name></Step>
        </Request>
        <Response/>
    </PreFlow>
    <PostFlow name="PostFlow">
        <Request/>
        <Response>
            <Step><Name>AM-SetVersionHeader</Name></Step>
        </Response>
    </PostFlow>
    <Flows/>
    <RouteRule name="default">
        <TargetEndpoint>default</TargetEndpoint>
    </RouteRule>
</ProxyEndpoint>
